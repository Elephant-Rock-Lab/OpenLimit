{
  "name": "@openlimit/sdk",
  "version": "1.2.0",
  "description": "TypeScript SDK for OpenLimit AI API Gateway",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "npx vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": ["openlimit", "ai", "gateway", "openai", "llm"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicklausw/openlimit",
    "directory": "sdks/typescript"
  },
  "engines": { "node": ">=18.0.0" }
}
